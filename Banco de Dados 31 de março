CREATE TABLE especime (
tombo
data_coleta
maturacao

PRIMARY KEY(tombo)
FOREIGN KEY(nome_campo) REFERENCES ENTIDADE(nome_campo),
FOREIGN KEY(numero) REFERENCES ENTIDADE(numero),
FOREIGN KEY(nome_exp) REFERENCES ENTIDADE(nome_exp),
);

	CREATE TABLE especie(
nome_campo VARCHAR,
nome_popular VARCHAR,
familia VARCHAR,

PRIMARY KEY(nome_campo)
);


CREATE TABLE etiqueta(
codigo INTEGER,
fabricante VARCHAR,

PRIMARY KEY(codigo)
FOREIGN KEY(tombo) REFERENCES ENTIDADE(tombo),
UNIQUE(tombo),
);

CREATE TABLE armario(
numero INTEGER,
capacidade INTEGER,

PRIMARY KEY(numero),

);


CREATE TABLE expedicoes(
nome_exp VARCHAR,
bioma VARCHAR,
data_exp INTEGER,

PRIMARY KEY(nome_exp)
);


CREATE TABLE pesquisadores(
cpf INTEGER,
nome_pesq VARCHAR,
instituicao VARCHAR,
);

CREATE TABLE exp_pesq(
nome_exp VARCHAR,
cpf INTEGER,

PRIMARY KEY(nome_exp,cpf )
FOREIGN KEY(nome_exp) REFERENCES ENTIDADE(nome_exp),
FOREIGN KEY(cpf) REFERENCES ENTIDADE(cpf), 
);


